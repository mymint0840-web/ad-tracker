generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(STAFF)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  entries       Entry[]

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

enum EntryProductType {
  PAGE
  CRM
}

model AdAccount {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entries   Entry[]

  @@map("ad_accounts")
}

model Page {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entries   Entry[]

  @@map("pages")
}

model Product {
  id            Int            @id @default(autoincrement())
  name          String
  cost          Decimal        @db.Decimal(12, 2)
  price         Decimal        @db.Decimal(12, 2)
  stock         Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  entries       Entry[]
  stockLogs     StockLog[]
  entryProducts EntryProduct[] @relation("EntryProducts")
  crmEntries    Entry[]        @relation("CrmProduct")

  @@map("products")
}

model Entry {
  id              Int      @id @default(autoincrement())
  date            DateTime @db.Date

  accountId       Int
  account         AdAccount @relation(fields: [accountId], references: [id])
  productId       Int
  product         Product   @relation(fields: [productId], references: [id])
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])

  pageId          Int?
  page            Page?     @relation(fields: [pageId], references: [id])

  crmProductId    Int?
  crmProduct      Product?  @relation("CrmProduct", fields: [crmProductId], references: [id])

  adCost          Decimal  @db.Decimal(12, 2)
  messages        Int      @default(0)
  closed          Int      @default(0)
  orders          Int      @default(0)

  salesFromPage   Decimal  @db.Decimal(12, 2) @default(0)
  quantity        Int      @default(0)

  hotSales        Decimal  @db.Decimal(12, 2) @default(0)
  crmOrders       Int      @default(0)
  crmSales        Decimal  @db.Decimal(12, 2) @default(0)
  crmQty          Int      @default(0)

  shippingCost    Decimal  @db.Decimal(12, 2) @default(0)
  packingCost     Decimal  @db.Decimal(12, 2) @default(0)
  adminCommission Decimal  @db.Decimal(12, 2) @default(0)

  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entryProducts   EntryProduct[]

  @@index([date])
  @@index([accountId])
  @@index([productId])
  @@index([pageId])
  @@index([date, accountId])
  @@index([date, productId])
  @@map("entries")
}

model EntryProduct {
  id        Int              @id @default(autoincrement())
  entryId   Int
  entry     Entry            @relation(fields: [entryId], references: [id], onDelete: Cascade)
  productId Int
  product   Product          @relation("EntryProducts", fields: [productId], references: [id])
  quantity  Int              @default(0)
  type      EntryProductType @default(PAGE)

  @@unique([entryId, productId, type])
  @@index([entryId])
  @@index([productId])
  @@map("entry_products")
}

model StockLog {
  id        Int       @id @default(autoincrement())
  productId Int
  product   Product   @relation(fields: [productId], references: [id])
  change    Int
  reason    String
  entryId   Int?
  createdAt DateTime  @default(now())

  @@index([productId])
  @@map("stock_logs")
}

model DailyTarget {
  id            Int      @id @default(autoincrement())
  profit        Decimal  @db.Decimal(12, 2) @default(0)
  adPercent     Decimal  @db.Decimal(5, 2) @default(0)
  closeRate     Decimal  @db.Decimal(5, 2) @default(0)
  costPerClick  Decimal  @db.Decimal(12, 2) @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("daily_targets")
}
